# ── backend/api ───────────────────────────────────────────────────────────
# Copy to backend/api/.env for local dev. Required-in-prod keys may be blank locally.
DATABASE_URL="postgresql://medrush:medrush@localhost:5432/medrush?connection_limit=10"
PORT=4000
NODE_ENV=development

# Firebase Admin (Phase 1 — optional in development)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Razorpay (Phase 2 — TEST keys locally, optional in development)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Cloudflare R2 (Phase 2 — optional in development)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BUCKET=medrush-public
R2_PRIVATE_BUCKET=medrush-private
R2_PUBLIC_CDN_URL=

# Maps / observability (optional in development)
OLA_MAPS_API_KEY=
SENTRY_DSN=

# Internal
REVALIDATE_SECRET=dev-revalidate-secret   # optional (no consumer yet; kept for the planned ISR hook)
BACKUP_GPG_PASSPHRASE=

# Backup hardening (Phase 7 — all optional; see docs/runbooks/restore.md + deploy.md)
BACKUP_HEARTBEAT_URL=                     # dead-man's-switch: GET after each successful nightly backup (e.g. Better Stack heartbeat)
BACKUP_RETENTION_DAYS=60                  # prune backup objects older than this after each successful upload
BACKUP_R2_BUCKET=                         # optional dedicated backups bucket (falls back to R2_PRIVATE_BUCKET)
BACKUP_R2_ACCOUNT_ID=                     # optional per-key overrides so a compromised runtime R2 key
BACKUP_R2_ACCESS_KEY_ID=                  #   cannot destroy backup history (each falls back to R2_*)
BACKUP_R2_SECRET_ACCESS_KEY=

# Proxy / rate-limit trust (Phase 7 hardening)
TRUST_PROXY_HOPS=                         # optional int; proxy hops trusted for client IP (unset → 1 in prod [Railway], full trust in dev)
RATE_LIMIT_TRUST_CF_HEADER=               # optional bool; key rate limits on CF-Connecting-IP — enable ONLY behind Cloudflare

# Seed safety: prisma/seed.ts refuses non-localhost DATABASE_URL unless SEED_FORCE_DESTRUCTIVE=yes
# (and always refuses NODE_ENV=production).
# SEED_FORCE_DESTRUCTIVE=yes

# CORS origins
WEB_ORIGIN=http://localhost:3000
OPS_ORIGIN=http://localhost:3001

# Optional
RESEND_API_KEY=

# ── frontend/ops & frontend/web (Phase 3–4) ──────────────────────────────
# NEXT_PUBLIC_API_URL=http://localhost:4000   # REQUIRED for production builds — next build/boot throws when unset (dev falls back to localhost)
# NEXT_PUBLIC_FIREBASE_API_KEY=               # Firebase phone-OTP login (Phase 7); unset in dev → dev-token login
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_RAZORPAY_KEY_ID=            # web only
# NEXT_PUBLIC_OLA_MAPS_KEY=
# NEXT_PUBLIC_SENTRY_DSN=
# NEXT_PUBLIC_SUPPORT_PHONE=              # web only — support/WhatsApp CTAs, e.g. +91XXXXXXXXXX; unset HIDES the CTAs (fake default removed)

# ── frontend/driver (Phase 5, EAS secrets) ───────────────────────────────
# EXPO_PUBLIC_API_URL=                    # REQUIRED for release builds — app throws at startup when unset/placeholder (dev falls back to 10.0.2.2)
# EXPO_PUBLIC_SENTRY_DSN=                 # Sentry crash reporting (no-op unless set)
# Driver Firebase auth uses google-services.json (operator-provided, gitignored), not EXPO_PUBLIC_FIREBASE_* env.
