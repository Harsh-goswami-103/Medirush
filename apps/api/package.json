{
  "name": "@medrush/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MedRush API — Fastify 5 + Prisma 6 + Socket.io + pg-boss",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/swagger": "^9.4.2",
    "@fastify/swagger-ui": "^5.2.1",
    "@medrush/contracts": "workspace:*",
    "@prisma/client": "^6.8.0",
    "fastify": "^5.6.0",
    "fastify-type-provider-zod": "^6.0.0",
    "firebase-admin": "^13.0.0",
    "pg-boss": "^10.1.6",
    "pino": "^9.6.0",
    "socket.io": "^4.8.1",
    "zod": "^4.1.0"
  },
  "devDependencies": {
    "@medrush/config": "workspace:*",
    "@types/node": "^22.13.0",
    "eslint": "^9.20.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.8.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
